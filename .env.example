# Copy this to .env for local dev, or set these in your hosting dashboard.
# NEVER commit .env to git.

# Minecraft server (overrides settings.json)
MC_HOST=kagiyanagi.aternos.me
MC_PORT=14021

# Bot account
BOT_USERNAME=Slobot00
BOT_PASSWORD=

# Auth plugin password (for /login, /register on the MC server)
AUTH_PASSWORD=

# Discord webhook URL (optional)
DISCORD_WEBHOOK=

# For Render: set this to your Render service URL so self-ping works
# RENDER_EXTERNAL_URL=https://your-service.onrender.com

# For Fly.io / Railway / other: set APP_URL instead
# APP_URL=https://your-app.fly.dev
